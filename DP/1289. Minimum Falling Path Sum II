class Solution {
    public int minFallingPathSum(int[][] matrix) {
        int n = matrix.length;
        int m = matrix[0].length;

        int[][] dp = new int[n][m];

        for(int i = 0; i< n; i++){
            Arrays.fill(dp[i] , (int)1e9);
        }
        int ans = (int)1e9;

        for(int j = 0; j< m; j++){
            ans = Math.min(ans,solve(0,j, n, m, matrix,dp));
        }
        return ans;
    }
    public int solve(int i, int j, int n, int m, int[][] matrix, int[][] dp){

        if(j < 0 || j > m-1)return (int)1e9;
        if(i == n-1)return matrix[i][j];

        if (dp[i][j] != (int)1e9) return dp[i][j];

        int min = (int)1e9;

        for(int k = 0; k< m; k++){
            if(k != j){
                min = Math.min(min, solve(i+1, k, n,m, matrix, dp));   
            }
    
        }        
        return dp[i][j] = matrix[i][j] + min;
    }
}
