class Solution {
    public boolean checkOnesSegment(String s) {
        int idx = -1;

        for(int i = 0; i < s.length(); i++){
            if(s.charAt(i) == '1' && idx != -1){
                if(i-idx > 1)return false;
            }
            if(s.charAt(i) == '1'){
                idx = i;
                
            }
        }
        return true;
    }
}
