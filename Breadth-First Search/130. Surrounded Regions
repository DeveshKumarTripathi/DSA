
class Solution {
    public void solve(char[][] grid) {
        int n = grid.length;
        int m = grid[0].length;
        for(int i = 0; i < m; i++){
            if(grid[0][i] == 'O')dfs(0,i,n,m,grid);
            if(grid[n-1][i] == 'O')dfs(n-1,i,n,m,grid);
        }
        for(int i = 0; i < n; i++){
            if(grid[i][0] == 'O')dfs(i,0,n,m,grid);
            if(grid[i][m-1] == 'O')dfs(i,m-1,n,m,grid);
        }
        for(int i = 0;i < n; i++){
            for(int j = 0; j < m; j++){
                if(grid[i][j] == '#'){
                    grid[i][j] = 'O';
                }else if(grid[i][j] == 'O'){
                    grid[i][j] = 'X';
                }
            }
        }return;   
    }
    public void dfs(int i, int j, int n, int m, char[][] grid){
        if(i<0||i>=n||j<0||j>=m||grid[i][j]!='O')return;
        grid[i][j]='#';
        dfs(i+1,j,n,m,grid);
        dfs(i-1,j,n,m,grid);
        dfs(i,j+1,n,m,grid);
        dfs(i,j-1,n,m,grid);
    }
}
