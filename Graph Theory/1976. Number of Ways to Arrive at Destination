class Solution {
    class Pair{
        int node;
        long dist;
        Pair(int node, long dist){
            this.node = node;
            this.dist = dist;
        }
    }
    public int countPaths(int n, int[][] roads) {
    
        ArrayList<ArrayList<Pair>> adj = new ArrayList<>();

        for (int i = 0; i < n; i++) {
            adj.add(new ArrayList<>());
        }
        for (int[] edge : roads) {
            int u = edge[0];
            int v = edge[1];
            int w = edge[2];

            adj.get(u).add(new Pair(v,w));
            adj.get(v).add(new Pair(u,w));  
        }

        long[] dist = new long[n];
        int[] ways = new int[n];

        Arrays.fill(dist,Long.MAX_VALUE);

        PriorityQueue<Pair> q = new PriorityQueue<>((a, b) -> Long.compare(a.dist , b.dist));
        q.add(new Pair(0, 0));
        
        dist[0] = 0;
        ways[0] = 1;

        int mod = (int)1e9 + 7;

        while(!q.isEmpty()){
            Pair curr = q.poll();
            
            int currNode = curr.node;
            long currDist = curr.dist;

            if (currDist > dist[currNode]) continue;
            
            for (Pair neighbor : adj.get(currNode)) {
                
                int adjNode = neighbor.node;
                long weight = neighbor.dist;

                if (currDist + weight < dist[adjNode]){

                    dist[adjNode] = currDist + weight;
                    q.add(new Pair(adjNode, dist[adjNode]));

                    ways[adjNode] = ways[currNode];
                }
                else if (currDist + weight == dist[adjNode]) {

                    ways[adjNode] = (ways[adjNode] + ways[currNode])%mod;
                }
            }           
        }
        return ways[n - 1];
    }
}
