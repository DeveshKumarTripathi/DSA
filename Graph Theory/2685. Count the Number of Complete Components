class Solution {
    public int countCompleteComponents(int n, int[][] edges) {
        ArrayList<ArrayList<Integer>> adj = new ArrayList<>();
        for(int i = 0; i < n; i++){
            adj.add(new ArrayList<>());
        }
        for(int[] e : edges){
            int u = e[0];
            int v = e[1];

            adj.get(u).add(v);
            adj.get(v).add(u);
        }
        boolean[] vis = new boolean[n];
        int count = 0;

        for(int i = 0; i < n; i++){
            if(!vis[i]){
                if(bfs(i, vis, adj)){
                    count++;
                }
            }
        }return count; 
    }
    public boolean bfs(int i, boolean[] vis, ArrayList<ArrayList<Integer>> adj){
        
        Queue<Integer> q = new LinkedList<>();
        q.add(i);

        vis[i] = true;

        int nodes = 0;
        int edges = 0;

        while(!q.isEmpty()){

            int curr = q.poll();

            nodes++;
            edges += adj.get(curr).size();

            for(int nei : adj.get(curr)){
                if(!vis[nei]){
                    vis[nei] = true;
                    q.add(nei);
                }
            }
        }
        edges /= 2;
        if(edges == (nodes*(nodes-1))/2)return true;
        return false;
    }
}
